have created the env file lcoaly there i wall paste the senidgrid api key ,also keep all keys daya here locally in mylaptop with gitinogred # FleetShield365 Backend — .env.example
#
# This file documents every environment variable consumed by the
# FastAPI backend (server.py). It MUST contain placeholders only —
# never commit real secrets. In production on EC2, the live `.env`
# file at /opt/fleetshield365/backend/.env is materialized at deploy
# time from AWS Systems Manager Parameter Store SecureString entries
# under /fleetshield365/prod/, with filesystem mode 0600 owned by root.
#
# See Requirement 3 ("Environment-Driven Secret Configuration") in
# .kiro/specs/infra-migration-subdomain-tenancy/requirements.md.

# -----------------------------------------------------------------------------
# Database (self-hosted MongoDB 7 Community on EC2, bound to 127.0.0.1:27017,
# single-node replica set `rs0`, keyfile authentication enabled).
# -----------------------------------------------------------------------------
MONGO_URL=mongodb://fleetshield:CHANGE_ME@127.0.0.1:27017/fleetguard_db?authSource=admin&replicaSet=rs0
DB_NAME=fleetguard_db

# -----------------------------------------------------------------------------
# JWT
# Rotate this value fresh as part of the Railway -> EC2 cutover.
# Startup will fail-fast if this is unset or empty.
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_to_a_long_random_string

# -----------------------------------------------------------------------------
# Stripe (billing + subscription webhooks)
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder

# -----------------------------------------------------------------------------
# SMTP (Namecheap PrivateEmail) — transactional email: password reset,
# alerts, contact form, weekly summaries, etc.
#
# SMTP_HOST       Namecheap PrivateEmail SMTP endpoint.
# SMTP_PORT       465 (SSL/TLS) or 587 (STARTTLS).
# SMTP_USER       Full mailbox address used to authenticate.
# SMTP_PASSWORD   Mailbox password. Startup logs a warning (but does not
#                 fail) when missing; emails will be mocked instead.
# SENDER_EMAIL    Address shown in the From: header.
# -----------------------------------------------------------------------------
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=alerts@fleetshield365.com
SMTP_PASSWORD=
SENDER_EMAIL=alerts@fleetshield365.com
CONTACT_RECIPIENT_EMAIL=contact@fleetshield365.com

# -----------------------------------------------------------------------------
# Platform owner bootstrap
# Comma-separated list of MongoDB ObjectId strings. Any user whose _id is
# listed here is minted a JWT with role="platform_owner", in addition to
# any user with users.is_platform_owner == true in the database.
# Leave empty once the seeded platform_owner user is promoted via the DB flag.
# -----------------------------------------------------------------------------
PLATFORM_OWNER_USER_IDS=

# -----------------------------------------------------------------------------
# Origins
# DEFAULT_ORIGIN_URL is the fallback host for password-reset links when the
# client does not pass origin_url explicitly (Requirement 6.1).
# CORS_ALLOWED_ORIGINS is a comma-separated allowlist; tenant subdomains
# *.fleetshield365.com are additionally matched by a regex in server.py.
# -----------------------------------------------------------------------------
DEFAULT_ORIGIN_URL=https://www.fleetshield365.com
CORS_ALLOWED_ORIGINS=https://fleetshield365.com,https://www.fleetshield365.com,https://app.fleetshield365.com,https://owner.fleetshield365.com

# -----------------------------------------------------------------------------
# ObjectStore (self-hosted MinIO on EC2, bound to 127.0.0.1:9000)
#
# OBJECT_STORE_ENDPOINT          Internal URL the backend uses to talk to MinIO.
# OBJECT_STORE_PUBLIC_ENDPOINT   Public host embedded in presigned GET URLs;
#                                must route through Nginx /files/ (Req 21.13).
# OBJECT_STORE_ACCESS_KEY/SECRET Programmatic, non-root credentials distinct
#                                from MINIO_ROOT_USER/PASSWORD. Startup will
#                                fail-fast if either is unset or empty.
# OBJECT_STORE_REGION            Any region string accepted by the S3 SDK.
# OBJECT_STORE_PRESIGN_TTL_SECONDS  Max lifetime of presigned GET URLs.
# -----------------------------------------------------------------------------
OBJECT_STORE_ENDPOINT=http://127.0.0.1:9000
OBJECT_STORE_PUBLIC_ENDPOINT=https://api.fleetshield365.com/files
OBJECT_STORE_ACCESS_KEY=minio_access_key_placeholder
OBJECT_STORE_SECRET_KEY=minio_secret_key_placeholder
OBJECT_STORE_REGION=us-east-1
OBJECT_STORE_PRESIGN_TTL_SECONDS=3600
